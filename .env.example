# Required: no defaults for any of these

# OpenRouter API key (used for both the LLM structuring call and embeddings).
OPENROUTER_API_KEY=


# The name of the embedding model you will be calling
OPENROUTER_EMBEDDING_MODEL=

# Output dimension of the chosen embedding model (sets the pgvector column
# size at migration time).
# make sure it matches the dimension output based on the embedding model of your choice since each model has different dimension
EMBEDDING_DIMENSIONS=

# LLM used for the structuring step
OPENROUTER_MODEL=

# Cosine-similarity cutoff between "distinct" (Case A) and "match" (Case B),
# strictly between 0 and 1. Needs empirical tuning on real data - no default.
# this should be adjusted to avoid false positive / false negative result
SIMILARITY_THRESHOLD=

WEBHOOK_SECRET_KEY=

# Optional

# Defaults to the docker-compose local instance.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nimbrosa

# Defaults to https://openrouter.ai/api/v1
#OPENROUTER_BASE_URL=

WEBHOOK_TIMESTAMP_TOLERANCE=

WEBHOOK_ENCODE_ALG=

WEBHOOK_DIGEST_METHOD=
